%% Smart Traffic Management System - Sequence Diagrams (Mermaid)

%% Sequence 1: Get Alternate Route
sequenceDiagram
  participant U as User (Browser)
  participant API as Backend REST
  participant RS as Routing Service
  participant GM as Google Maps API
  participant DB as DB

  U->>API: Request route(origin, destination)
  API->>RS: Build routing query with constraints
  RS->>GM: Directions API + Traffic layer
  GM-->>RS: Routes with durations, traffic data
  RS->>DB: Log query/metrics
  RS-->>API: Best route + alternatives
  API-->>U: RouteSuggestion DTOs

%% Sequence 2: Report Incident
sequenceDiagram
  participant U as User (Browser)
  participant API as Backend REST
  participant REP as Reports Service
  participant GM as Google Maps API
  participant DB as DB

  U->>API: Submit report(type, location, note)
  API->>REP: Validate + normalize payload
  REP->>GM: Reverse geocode (optional)
  GM-->>REP: Address metadata
  REP->>DB: Save IncidentReport(status=Open)
  REP-->>API: ReportId, status
  API-->>U: Confirmation + display on map


